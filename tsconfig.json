{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "lib"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "generated",
    "lib",
    "prisma.config.ts"
  ]
}